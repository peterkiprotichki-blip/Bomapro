{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/bomapro-frontend",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bomapro-backend.vercel.app/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}

